# --- Database Configuration ---
POSTGRES_DB=chatdb
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpass
POSTGRES_PORT=5432

# --- Application Ports & URLs ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Database Connection ---
DATABASE_URL=postgresql+asyncpg://chatuser:chatpass@db:5432/chatdb

# --- Security & Authentication ---
CORS_ORIGINS=http://localhost:3000
JWT_EXP_SECONDS=3600
JWT_DEFAULT_ALG=ES256

# WARNING: All algorithms (ES256, ES384, ES512) are assigned the same key pair.
# Ensure you are using the correct key pair for production!
JWT_KEYS_JSON={"ES256":{"private_b64":"PASTE_BASE64_PEM_HERE","public_b64":"PASTE_BASE64_PEM_HERE"},"ES384":{"private_b64":"PASTE_BASE64_PEM_HERE","public_b64":"PASTE_BASE64_PEM_HERE"},"ES512":{"private_b64":"PASTE_BASE64_PEM_HERE","public_b64":"PASTE_BASE64_PEM_HERE"}}
# --- Public Client Variables ---
NEXT_PUBLIC_API_URL=http://localhost:8000
